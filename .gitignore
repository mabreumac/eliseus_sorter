.venv/
dist/
__pycache__/
*.py[cod]
.DS_Store

# --- Anonymity: never commit student data or identifiers ---

# Entire local data tree (folder names, photos)
data/*/*

# Generated reports (match_report_*.json/csv, manifests, etc.)
results/*/*

# Photos / media anywhere in the repo
*.jpg
*.jpeg
*.png
*.webp
*.bmp
*.tif
*.tiff
*.heic
*.raw
*.dng

# Databases and embedding cache
*.db
*.sqlite
*.sqlite3

# Generated match reports (if saved outside data/)
match_report_*.json
match_report_*.csv

# Local env / secrets
.env
.env.*

# Installer log (may contain local paths)
install.log
